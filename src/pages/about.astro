---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const siteUrl = SITE?.site || 'https://best-studio-6yx.pages.dev';

const metadata = {
  title: '关于 Best Studio | 经济学 PhD、RA、Predoc 中文申请指南',
  ignoreTitleTemplate: true,
  description: '关于 Best Studio：面向中国学生的学术早期职业知识库，覆盖科研经历、RA、Predoc 和 PhD 申请四个核心主题。',
  canonical: '/about',
  openGraph: { type: 'website', url: '/about' },
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Lauren Qu',
  url: `${siteUrl}/about`,
  jobTitle: 'Pre-doctoral Research Fellow',
  affiliation: {
    '@type': 'CollegeOrUniversity',
    name: 'Massachusetts Institute of Technology',
    sameAs: 'https://www.mit.edu',
  },
  knowsAbout: [
    'Economics PhD Applications',
    'Research Assistantship',
    'Pre-doctoral Fellowship',
    'Academic Career Planning',
    'Statement of Purpose Writing',
  ],
  description: '经济学 Predoc，专注于帮助中国学生理解学术早期职业路径的规划与申请。',
  sameAs: [],
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: 'Best Studio',
  url: siteUrl,
  description: '面向中国学生的学术早期职业规划平台，专注经济学 PhD、RA、Predoc 申请的深度中文指南。',
  founder: { '@type': 'Person', name: 'Lauren Qu' },
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">首页</a><span class="mx-2">/</span><span>关于</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">About</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      Best Studio 是一个以判断力为核心的知识库。
    </h1>
    <p class="mt-5 text-xl text-muted">
      它帮助研究导向的中国学生理解学术早期职业决策：要不要做科研、如何积累可信的科研经历、RA 和 Predoc
      什么时候有用，以及 PhD 申请真正看什么。
    </p>
  </section>

  <!-- 编辑立场 -->
  <section class="px-4 md:px-6 py-8 mx-auto max-w-4xl">
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>编辑立场</h2>
      <p>
        Best Studio 的所有内容只有一个来源：真实的申请过程和有记录的经验。文章里的每一条建议都需要能说出理由，不接受「大家都这么做」或「感觉应该如此」作为依据。
      </p>
      <p>
        我们覆盖的读者有一个共同特征：他们是研究导向的，他们正处于某个真实的决策点上，他们需要的是可以帮助他们做判断的信息，而不是信心喊话或经历堆砌。
      </p>
      <p>
        这个知识库的内容按照真实的申请路径组织，从「要不要走科研这条路」开始，经过「如何积累有含金量的科研经历」，到「RA 和 Predoc 各适合什么情况」，最后到「PhD 申请材料怎么准备」。每个 Hub 覆盖一个决策阶段，每篇指南聚焦一个具体问题。
      </p>

      <h2>覆盖范围</h2>
      <p>
        Best Studio 覆盖经济学、政策和社会科学方向的学术职业早期路径，重点面向中国学生申请北美 PhD 项目的场景。内容涉及：
      </p>
      <ul>
        <li><a href="/research-careers">科研职业路径判断</a>：你适合走学术路线吗？读 PhD 的机会成本有多高？</li>
        <li><a href="/research-experience">科研经历积累</a>：什么是真正有价值的 RA 经历？如何找到第一段机会？</li>
        <li><a href="/ra-predoc">RA 与 Predoc</a>：二者的真实区别、Predoc 值不值得做、如何判断项目质量</li>
        <li><a href="/phd-applications">PhD 申请</a>：CV、SOP、推荐信、面试、选校、时间线</li>
      </ul>

      <h2>内容边界</h2>
      <p>
        这个知识库不覆盖以下内容：MBA 申请、工业界求职、非学术方向的职业规划、签证和移民政策的具体法律建议、以及和科研路径无关的通用留学指南。
      </p>
      <p>
        对于需要根据个人情况具体分析的问题，文章会说明通用框架，但不会代替针对个人的判断。这类情况更适合通过 <a href="/mentoring">1 对 1 辅导</a> 来处理。
      </p>

      <h2>如何使用这个知识库</h2>
      <p>
        如果你刚开始了解这个领域，建议从 <a href="/start-here">「从这里开始」</a> 找到最贴近你当前处境的起点。如果你知道自己需要什么，可以直接进入对应的 Hub 或用搜索找到具体文章。
      </p>
    </div>
  </section>

  <!-- 导读 -->
  <section class="px-4 md:px-6 py-10 mx-auto max-w-4xl">
    <h2 class="text-2xl font-bold tracking-tight">最常被阅读的文章</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      <a class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary transition-colors" href="/guides/should-you-do-phd">
        <span class="text-xs font-semibold uppercase tracking-wide text-primary">科研职业</span>
        <p class="mt-2 font-semibold leading-snug">你真的适合读 PhD 吗？</p>
      </a>
      <a class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary transition-colors" href="/guides/how-to-find-first-ra-opportunity">
        <span class="text-xs font-semibold uppercase tracking-wide text-primary">科研经历</span>
        <p class="mt-2 font-semibold leading-snug">如何找到第一段 RA 机会？</p>
      </a>
      <a class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary transition-colors" href="/guides/predoc-complete-guide">
        <span class="text-xs font-semibold uppercase tracking-wide text-primary">RA & Predoc</span>
        <p class="mt-2 font-semibold leading-snug">什么是 Predoc？经济学 Predoc 完整指南</p>
      </a>
      <a class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary transition-colors" href="/guides/recommendation-letters">
        <span class="text-xs font-semibold uppercase tracking-wide text-primary">PhD 申请</span>
        <p class="mt-2 font-semibold leading-snug">推荐信：招生委员会真正看什么？</p>
      </a>
    </div>
    <div class="mt-6 flex gap-4">
      <a class="btn-primary" href="/start-here">找到你的起点</a>
      <a class="btn" href="/guides">浏览全部指南</a>
    </div>
  </section>
</Layout>
