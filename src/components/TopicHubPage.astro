---
import Layout from '~/layouts/PageLayout.astro';
import {
  getClusterCaseStudyPage,
  getClusterFaqPage,
  getClusterItems,
  statusLabels,
  topicClusters,
  topicPath,
  typeLabels,
  type ClusterItem,
  type TopicCluster,
} from '~/data/topicClusters';

const { cluster } = Astro.props as { cluster: TopicCluster };

const metadata = {
  title: `${cluster.title} | Best Studio`,
  description: cluster.description,
  canonical: `/${cluster.slug}`,
  openGraph: {
    type: 'website',
    url: `/${cluster.slug}`,
  },
};

const statusClass = {
  Published: 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-200',
  Draft: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-200',
  Planned: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-200',
};

const typeClass = {
  Decision: 'border-blue-200 text-blue-800 dark:border-blue-800 dark:text-blue-200',
  Guide: 'border-emerald-200 text-emerald-800 dark:border-emerald-800 dark:text-emerald-200',
  Myth: 'border-amber-200 text-amber-800 dark:border-amber-800 dark:text-amber-200',
  Resource: 'border-violet-200 text-violet-800 dark:border-violet-800 dark:text-violet-200',
  Data: 'border-slate-200 text-slate-800 dark:border-slate-700 dark:text-slate-200',
  FAQ: 'border-cyan-200 text-cyan-800 dark:border-cyan-800 dark:text-cyan-200',
  'Case Study': 'border-rose-200 text-rose-800 dark:border-rose-800 dark:text-rose-200',
};

const allItems = await getClusterItems(cluster.slug);
const guides = allItems.filter((item) => item.type === 'Guide');
const decisions = allItems.filter((item) => item.type === 'Decision');
const faqPage = getClusterFaqPage(cluster);
const caseStudyPage = getClusterCaseStudyPage(cluster);
const relatedClusters = topicClusters.filter((item) => item.slug !== cluster.slug);

const linkList = (items: ClusterItem[]) =>
  items.length
    ? items
    : [
        {
          slug: `${cluster.slug}-future-slot`,
          title: '未来占位',
          type: 'Guide' as const,
          status: 'Planned' as const,
          href: '#',
        },
      ];
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">首页</a>
      <span class="mx-2">/</span>
      <span>{cluster.title}</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">{cluster.kicker}</p>
    <div class="mt-4 grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div>
        <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">{cluster.title}</h1>
        <p class="mt-5 text-xl text-muted">{cluster.description}</p>
      </div>
      <div class="border-l-4 border-primary bg-gray-50 dark:bg-slate-900 p-5">
        <p class="text-sm font-semibold text-muted">核心问题</p>
        <p class="mt-2 text-2xl font-semibold leading-snug">{cluster.primaryQuestion}</p>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-6xl">
    <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">本页目录</h2>
        <ol class="mt-4 space-y-2 text-sm text-muted">
          <li><a class="hover:underline" href="#introduction">关于这个主题</a></li>
          <li><a class="hover:underline" href="#pillars">内容支柱</a></li>
          <li><a class="hover:underline" href="#all-content">全部内容</a></li>
          <li><a class="hover:underline" href="#faq">常见问题</a></li>
          <li><a class="hover:underline" href="#internal-links">相关主题</a></li>
        </ol>
      </div>
      <div id="introduction" class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">关于这个主题</h2>
        <div class="mt-3 space-y-3 text-muted">
          {cluster.intro.split('\n\n').map((para) => <p>{para}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="grid gap-6 md:grid-cols-3">
      <div>
        <h2 class="text-lg font-bold">适合谁阅读</h2>
        <ul class="mt-4 space-y-3 text-muted">
          {cluster.audience.map((item) => <li class="border-l border-gray-200 pl-4 dark:border-slate-700">{item}</li>)}
        </ul>
      </div>
      <div id="pillars" class="md:col-span-2">
        <h2 class="text-lg font-bold">内容支柱</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          {
            cluster.pillars.map((pillar) => (
              <div class="border border-gray-200 dark:border-slate-700 p-4">
                <p class="font-medium">{pillar.title}</p>
                <p class="mt-2 text-sm text-muted">{pillar.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="all-content" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary">全部内容</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight">指南、决策与资源</h2>
      </div>
      <a class="text-sm font-semibold text-primary hover:underline" href="/content-map">查看完整内容地图</a>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {
        allItems.map((item) => (
          <article class="border border-gray-200 dark:border-slate-700 p-5">
            <div class="flex flex-wrap items-center gap-2">
              <span class={`rounded-full border px-2.5 py-1 text-xs font-semibold ${typeClass[item.type]}`}>
                {typeLabels[item.type]}
              </span>
              <span class={`rounded-full px-2.5 py-1 text-xs font-semibold ${statusClass[item.status]}`}>
                {statusLabels[item.status]}
              </span>
            </div>
            <h3 class="mt-4 text-lg font-bold">
              <a class="hover:underline" href={item.href}>
                {item.title}
              </a>
            </h3>
          </article>
        ))
      }
    </div>
  </section>

  <section id="faq" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">常见问题</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight">读者最常问的问题</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      {
        cluster.faqs.map((faq) => (
          <div class="border border-gray-200 dark:border-slate-700 p-5">
            <h3 class="font-bold">{faq.q}</h3>
            <p class="mt-2 text-sm text-muted">{faq.a}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="internal-links" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">相关主题</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight">按类型浏览</h2>
    <div class="mt-6 grid gap-5 md:grid-cols-5">
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">指南页</h3>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {
            linkList(guides).map((item) => (
              <li>
                <a class="hover:underline" href={item.href}>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">决策页</h3>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {
            linkList(decisions).map((item) => (
              <li>
                <a class="hover:underline" href={item.href}>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">FAQ 页</h3>
        <a class="mt-3 block text-sm text-muted hover:underline" href={topicPath(faqPage)}>{faqPage.title}</a>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">案例页</h3>
        <a class="mt-3 block text-sm text-muted hover:underline" href={topicPath(caseStudyPage)}
          >{caseStudyPage.title}</a
        >
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">相关主题</h3>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {
            relatedClusters.map((item) => (
              <li>
                <a class="hover:underline" href={`/${item.slug}`}>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-12 mx-auto max-w-6xl">
    <div class="border border-primary/40 bg-gray-50 dark:bg-slate-900 p-6 md:p-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">需要个人指导？</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight">每个人的情况都不一样。</h2>
      <p class="mt-3 text-muted">文章能解决通用问题，但你的背景、时间线和目标是独特的。如果你想针对自己的情况做具体判断，可以预约 1 对 1 辅导。</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/mentoring">了解辅导服务</a>
        <a class="btn" href="/start-here">从这里开始阅读</a>
      </div>
    </div>
  </section>
</Layout>
