---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
  description: 'About Best Studio and its academic career planning knowledge base.',
  canonical: '/about',
  openGraph: {
    type: 'website',
    url: '/about',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">Home</a>
      <span class="mx-2">/</span>
      <span>About</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">About</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      Best Studio is a decision-focused knowledge base.
    </h1>
    <p class="mt-5 text-xl text-muted">
      The site helps research-oriented students reason through early academic career decisions: whether to pursue
      research, how to build credible experience, when RA and predoc roles help, and how PhD applications are evaluated.
    </p>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-4xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-6">
        <h2 class="text-xl font-bold">What Belongs Here</h2>
        <p class="mt-3 text-muted">
          Future about-page content should explain the editorial point of view, scope, and boundaries of the knowledge
          base.
        </p>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-6">
        <h2 class="text-xl font-bold">What Does Not Belong Here</h2>
        <p class="mt-3 text-muted">
          This page should not become a generic agency profile, broad service catalog, or unrelated company history.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-10 mx-auto max-w-4xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Table of Contents Placeholder</h2>
        <p class="mt-3 text-sm text-muted">Editorial scope, boundaries, related articles, and future FAQ.</p>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Related Articles Placeholder</h2>
        <p class="mt-3 text-sm text-muted">Future orientation articles will appear here.</p>
      </div>
    </div>
  </section>
</Layout>
