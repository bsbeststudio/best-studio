---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Best Studio · 学术早期职业规划',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: '阅读指南',
        href: '/guides',
        icon: 'tabler:book',
      },
      { text: '申请辅导', href: '/mentoring' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Best Studio' }}
  >
    <Fragment slot="title">
      你现在的处境
      <br />
      <span class="text-accent">到底怎样？下一步该怎么走？</span>
    </Fragment>

    <Fragment slot="subtitle">
      面向有研究经历、正在考虑 Predoc 或经济学 PhD 的中国学生。
      我们提供的不是服务清单，而是判断力——帮你看清自己的处境，做出适合自己的决定。
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note
    title="核心立场："
    description="推荐信比 GPA 重要。PI 热情不等于录取。Predoc 不是保底选项。我们只说市面上不说的话。"
  />

  <!-- Who It's For Widget ************ -->

  <Features2
    id="who"
    title="适合哪些人"
    subtitle="无论你处于哪个阶段，核心问题都是一样的：我现在够吗？我下一步该做什么？"
    tagline="适用人群"
    columns={3}
    items={[
      {
        title: '本科生',
        description:
          '正在积累研究经历，想知道自己的背景是否够申请 Predoc 或直接申请 PhD，不确定该优先做什么。',
        icon: 'tabler:school',
      },
      {
        title: '硕士生',
        description:
          '已有一定学术背景，考虑是否值得继续读 PhD，或者如何通过 Predoc 弥补研究经历的不足。',
        icon: 'tabler:certificate',
      },
      {
        title: 'RA / Research Assistant',
        description:
          '在实验室或机构做 RA，想知道当前的经历是否足够、推荐信质量如何、申请时机是否成熟。',
        icon: 'tabler:microscope',
      },
      {
        title: 'Predoc 申请者',
        description:
          '正在申请 Predoc，需要了解哪些项目适合自己、材料如何准备、如何与教授建立有效联系。',
        icon: 'tabler:file-search',
      },
      {
        title: 'PhD 申请者',
        description:
          '准备申请经济学、金融、公共政策等研究型 PhD，需要有人帮你判断申请策略是否合理。',
        icon: 'tabler:building-community',
      },
      {
        title: '早期研究者',
        description:
          '已经进入 PhD 项目或刚开始科研生涯，面临方向选择或导师关系问题，需要过来人的视角。',
        icon: 'tabler:chart-line',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Common Decisions Widget ******** -->

  <Features2
    id="decisions"
    title="你正在面对的问题"
    subtitle="这些决策没有标准答案，但有的人比你更早经历过——而且愿意直接告诉你。"
    tagline="常见决策"
    columns={2}
    items={[
      {
        title: '我适不适合申请 Predoc？',
        description:
          'Predoc 不是万能跳板，也不是读不了 PhD 的安慰奖。它适合特定背景、特定目标的人。你需要先弄清楚自己算哪种情况。',
        icon: 'tabler:help-circle',
      },
      {
        title: '我的背景现在有多竞争力？',
        description:
          'GPA、科研经历、推荐信、发表——这几项的相对权重和你想的可能不一样。我们会告诉你委员会真正在看什么。',
        icon: 'tabler:award',
      },
      {
        title: '美国、英国、欧洲还是香港？',
        description:
          '不同体系在招生逻辑、Predoc 生态、导师关系上差异很大。选错方向会浪费一年甚至更多。',
        icon: 'tabler:world',
      },
      {
        title: '我应该怎么建立研究经历？',
        description:
          '不是所有 RA 经历都算数。教授的热情不等于你能拿到有价值的推荐信。我们帮你辨别哪些经历真正有用。',
        icon: 'tabler:git-branch',
      },
    ]}
  />

  <!-- Why Best Studio Widget ********* -->

  <Features
    id="why"
    tagline="为什么是我们"
    title="判断力，不是服务清单"
    subtitle="市面上的申请机构很多，但大多数卖的是流程，不是判断。我们不一样。"
    columns={3}
    items={[
      {
        title: '独立判断',
        description:
          '我们不向任何项目输送学生，没有机构利益。UChicago PhD 背景提供的是第一手认知，不是二手整理。',
        icon: 'tabler:scale',
      },
      {
        title: '基于证据的建议',
        description:
          '我们愿意说反常识的东西——包括你现在的背景不够、某个方向不适合你。不说好听话，只说有用的。',
        icon: 'tabler:clipboard-data',
      },
      {
        title: '长期规划视角',
        description:
          '我们关注的不是帮你通过这一次申请，而是帮你建立对整个学术早期职业路径的清醒认识。',
        icon: 'tabler:map-2',
      },
    ]}
  />

  <!-- Latest Guides Widget *********** -->

  <BlogLatestPosts
    title="最新指南"
    information="每篇指南都聚焦一个具体决策或认知盲区。读完之后，你应该对自己的处境有更清晰的判断。"
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '申请辅导',
        href: '/mentoring',
        icon: 'tabler:message-circle',
      },
      {
        text: '先看指南',
        href: '/guides',
      },
    ]}
  >
    <Fragment slot="title">
      需要有人帮你看清处境？
    </Fragment>

    <Fragment slot="subtitle">
      一对一辅导的核心是判断力，不是改简历。<br class="hidden md:inline" />
      我们会直接告诉你：你现在的背景够不够，下一步该怎么走。
    </Fragment>
  </CallToAction>
</Layout>
