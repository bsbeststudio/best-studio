---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import { getTopicPages } from '~/data/topicClusters';

export const prerender = true;

export const getStaticPaths = (() =>
  getTopicPages().map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }))) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { topic } = Astro.props as Props;
const headings = topic.headings ?? [];

const metadata = {
  title: `${topic.title} | Best Studio`,
  description: topic.description,
  canonical: topic.canonical,
  openGraph: {
    type: 'article',
    url: topic.canonical,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      {
        topic.breadcrumbs.map((item, index) => (
          <>
            {index > 0 && <span class="mx-2">/</span>}
            {index < topic.breadcrumbs.length - 1 ? (
              <a class="hover:underline" href={item.href}>
                {item.text}
              </a>
            ) : (
              <span>{item.text}</span>
            )}
          </>
        ))
      }
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">{topic.type} Placeholder</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">{topic.title}</h1>
    <p class="mt-5 text-xl text-muted">
      This page intentionally contains headings only. Detailed content will be added later when the article is ready.
    </p>
  </section>

  <section class="px-4 md:px-6 pb-8 mx-auto max-w-4xl">
    <div class="border border-gray-200 dark:border-slate-700 p-5">
      <h2 class="text-lg font-bold">Table of Contents Placeholder</h2>
      <ol class="mt-4 space-y-2 text-sm text-muted">
        {headings.map((heading) => <li>{heading}</li>)}
      </ol>
    </div>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-4xl">
    <div class="space-y-8">
      {
        headings.map((heading) => (
          <h2 class="border-b border-gray-200 pb-3 text-2xl font-bold dark:border-slate-700">{heading}</h2>
        ))
      }
    </div>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-4xl">
    <div class="border border-gray-200 dark:border-slate-700 p-5">
      <h2 class="text-lg font-bold">Related Articles Placeholder</h2>
      <p class="mt-3 text-sm text-muted">
        Future related article links from the {topic.cluster.title} hub will appear here.
      </p>
    </div>
  </section>
</Layout>
