---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '关于',
  description: '关于 Best Studio：面向中国学生的学术早期职业规划知识库。',
  canonical: '/about',
  openGraph: { type: 'website', url: '/about' },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">首页</a><span class="mx-2">/</span><span>关于</span>
    </nav>
  </section>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">About</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      Best Studio 是一个以判断力为核心的知识库。
    </h1>
    <p class="mt-5 text-xl text-muted">
      它帮助研究导向的中国学生理解学术早期职业决策：要不要做科研、如何积累可信的科研经历、RA 和 Predoc
      什么时候有用，以及 PhD 申请真正看什么。
    </p>
  </section>
  <section class="px-4 md:px-6 py-8 mx-auto max-w-4xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-6">
        <h2 class="text-xl font-bold">这里应该放什么</h2><p class="mt-3 text-muted">
          未来会说明 Best Studio 的编辑立场、覆盖范围和能力边界。
        </p>
      </div><div class="border border-gray-200 dark:border-slate-700 p-6">
        <h2 class="text-xl font-bold">这里不应该放什么</h2><p class="mt-3 text-muted">
          这个页面不应该变成泛泛的公司介绍、服务清单或无关历史。
        </p>
      </div>
    </div>
  </section>
  <section class="px-4 md:px-6 py-10 mx-auto max-w-4xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">目录占位</h2><p class="mt-3 text-sm text-muted">
          编辑范围、边界、相关文章和未来 FAQ。
        </p>
      </div><div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">相关文章占位</h2><p class="mt-3 text-sm text-muted">
          未来站点导读文章会放在这里。
        </p>
      </div>
    </div>
  </section>
</Layout>
