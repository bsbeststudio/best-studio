---
import Layout from '~/layouts/PageLayout.astro';
import {
  getClusterCaseStudyPage,
  getClusterFaqPage,
  topicClusters,
  topicPath,
  type TopicCluster,
  type TopicPlaceholder,
} from '~/data/topicClusters';

const { cluster } = Astro.props as { cluster: TopicCluster };

const metadata = {
  title: `${cluster.title} | Best Studio`,
  description: cluster.description,
  canonical: `/${cluster.slug}`,
  openGraph: {
    type: 'website',
    url: `/${cluster.slug}`,
  },
};

const statusClass = {
  Published: 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-200',
  Draft: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-200',
  Planned: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-200',
};

const typeClass = {
  Decision: 'border-blue-200 text-blue-800 dark:border-blue-800 dark:text-blue-200',
  Guide: 'border-emerald-200 text-emerald-800 dark:border-emerald-800 dark:text-emerald-200',
  Myth: 'border-amber-200 text-amber-800 dark:border-amber-800 dark:text-amber-200',
  Resource: 'border-violet-200 text-violet-800 dark:border-violet-800 dark:text-violet-200',
  Data: 'border-slate-200 text-slate-800 dark:border-slate-700 dark:text-slate-200',
  FAQ: 'border-cyan-200 text-cyan-800 dark:border-cyan-800 dark:text-cyan-200',
  'Case Study': 'border-rose-200 text-rose-800 dark:border-rose-800 dark:text-rose-200',
};

const guides = cluster.placeholders.filter((item) => item.type === 'Guide');
const decisions = cluster.placeholders.filter((item) => item.type === 'Decision');
const faqPage = getClusterFaqPage(cluster);
const caseStudyPage = getClusterCaseStudyPage(cluster);
const relatedClusters = topicClusters.filter((item) => item.slug !== cluster.slug);

const linkList = (items: TopicPlaceholder[]) =>
  items.length
    ? items
    : [
        {
          slug: `${cluster.slug}-future-slot`,
          title: 'Future placeholder',
          type: 'Guide' as const,
          status: 'Planned' as const,
        },
      ];
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">Home</a>
      <span class="mx-2">/</span>
      <span>{cluster.title}</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">{cluster.kicker}</p>
    <div class="mt-4 grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div>
        <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">{cluster.title}</h1>
        <p class="mt-5 text-xl text-muted">{cluster.description}</p>
      </div>
      <div class="border-l-4 border-primary bg-gray-50 dark:bg-slate-900 p-5">
        <p class="text-sm font-semibold text-muted">Primary question</p>
        <p class="mt-2 text-2xl font-semibold leading-snug">{cluster.primaryQuestion}</p>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-6xl">
    <div class="grid gap-6 lg:grid-cols-[0.75fr_1.25fr]">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Table of Contents Placeholder</h2>
        <ol class="mt-4 space-y-2 text-sm text-muted">
          <li><a class="hover:underline" href="#introduction">Introduction</a></li>
          <li><a class="hover:underline" href="#topic-clusters">Topic clusters</a></li>
          <li><a class="hover:underline" href="#related-guides">Related guides</a></li>
          <li><a class="hover:underline" href="#faq">FAQ</a></li>
          <li><a class="hover:underline" href="#internal-links">Internal links</a></li>
        </ol>
      </div>
      <div id="introduction" class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Short Introduction</h2>
        <p class="mt-3 text-muted">
          This hub is a planning container for future articles, decision pages, resources, FAQ entries, and case
          studies. The current page intentionally keeps the copy light so the structure can support a large knowledge
          base without filler content.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="grid gap-6 md:grid-cols-3">
      <div>
        <h2 class="text-lg font-bold">Who This Hub Is For</h2>
        <ul class="mt-4 space-y-3 text-muted">
          {cluster.audience.map((item) => <li class="border-l border-gray-200 pl-4 dark:border-slate-700">{item}</li>)}
        </ul>
      </div>
      <div class="md:col-span-2">
        <h2 class="text-lg font-bold">Content Pillars</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          {
            cluster.pillars.map((item) => (
              <div class="border border-gray-200 dark:border-slate-700 p-4">
                <p class="font-medium">{item}</p>
                <p class="mt-2 text-sm text-muted">Future articles in this pillar will live here.</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="topic-clusters" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary">Topic Clusters</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight">Planned topic pages</h2>
      </div>
      <a class="text-sm font-semibold text-primary hover:underline" href="/content-map">View content map</a>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {
        cluster.placeholders.map((item) => (
          <article class="border border-gray-200 dark:border-slate-700 p-5">
            <div class="flex flex-wrap items-center gap-2">
              <span class={`rounded-full border px-2.5 py-1 text-xs font-semibold ${typeClass[item.type]}`}>
                {item.type}
              </span>
              <span class={`rounded-full px-2.5 py-1 text-xs font-semibold ${statusClass[item.status]}`}>
                {item.status}
              </span>
            </div>
            <h3 class="mt-4 text-lg font-bold">
              <a class="hover:underline" href={topicPath(item)}>
                {item.title}
              </a>
            </h3>
            <p class="mt-2 text-sm text-muted">
              Placeholder page with headings only, SEO metadata, breadcrumbs, table of contents, and related article
              slots.
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="related-guides" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">Related Guides</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight">Guide pages in this hub</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {
        linkList(guides).map((item) => (
          <a class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary" href={topicPath(item)}>
            {item.title}
          </a>
        ))
      }
    </div>
  </section>

  <section id="faq" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">FAQ Section</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight">Questions to answer later</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h3 class="font-bold">What belongs in this hub?</h3>
        <p class="mt-2 text-sm text-muted">Placeholder for a short answer.</p>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h3 class="font-bold">Where should beginners start?</h3>
        <p class="mt-2 text-sm text-muted">Placeholder for a short answer.</p>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h3 class="font-bold">Which article should be written next?</h3>
        <p class="mt-2 text-sm text-muted">Placeholder for a short answer.</p>
      </div>
    </div>
  </section>

  <section id="internal-links" class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">Internal Links</p>
    <h2 class="mt-2 text-3xl font-bold tracking-tight">Automatic link groups</h2>
    <div class="mt-6 grid gap-5 md:grid-cols-5">
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">Guide Pages</h3>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {
            linkList(guides).map((item) => (
              <li>
                <a class="hover:underline" href={topicPath(item)}>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">Decision Pages</h3>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {
            linkList(decisions).map((item) => (
              <li>
                <a class="hover:underline" href={topicPath(item)}>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">FAQ Pages</h3>
        <a class="mt-3 block text-sm text-muted hover:underline" href={topicPath(faqPage)}>{faqPage.title}</a>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">Case Studies</h3>
        <a class="mt-3 block text-sm text-muted hover:underline" href={topicPath(caseStudyPage)}
          >{caseStudyPage.title}</a
        >
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-4">
        <h3 class="font-bold">Related Topics</h3>
        <ul class="mt-3 space-y-2 text-sm text-muted">
          {
            relatedClusters.map((item) => (
              <li>
                <a class="hover:underline" href={`/${item.slug}`}>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-12 mx-auto max-w-6xl">
    <div class="border border-primary/40 bg-gray-50 dark:bg-slate-900 p-6 md:p-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">CTA</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight">Use this hub as the planning spine.</h2>
      <p class="mt-3 text-muted">
        Add detailed articles only when the topic has a clear decision role, evidence role, or resource role inside this
        cluster.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/start-here">Start Here</a>
        <a class="btn" href="/mentoring">Mentoring</a>
      </div>
    </div>
  </section>
</Layout>
