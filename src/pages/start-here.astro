---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Start Here · Best Studio',
  description:
    '不知道从哪里开始？这里帮你快速定位自己的阶段，找到最适合你的资源。',
};
---

<Layout metadata={metadata}>
  <!-- Hero *************************** -->

  <HeroText
    tagline="Start Here"
    title="先搞清楚你在哪里，再决定往哪里走"
    subtitle="Best Studio 是一个学术早期职业决策知识库。这个页面帮你快速找到适合自己阶段的内容——不用从头看所有指南。"
  />

  <!-- Self-identification ************ -->

  <Features2
    id="stage"
    title="你现在处于哪个阶段？"
    subtitle="不同阶段面对的核心问题不同。找到你的位置，直接跳到最相关的内容。"
    tagline="找到你的位置"
    columns={2}
    items={[
      {
        title: '本科生，还没有明确的科研经历',
        description:
          '优先读：如何选研究方向、如何找第一个 RA 机会、本科阶段的推荐信怎么积累。核心问题是：科研适不适合我？',
        icon: 'tabler:school',
        callToAction: {
          text: '→ 读：如何建立研究经历',
          href: '/guides',
          variant: 'link',
        },
      },
      {
        title: '本科生，有一定科研经历，考虑 Predoc 或 PhD',
        description:
          '优先读：Predoc 是什么、要不要做 Predoc、我的背景够申请什么项目。核心问题是：我现在够吗？',
        icon: 'tabler:flask',
        callToAction: {
          text: '→ 读：Should I Do a Predoc?',
          href: '/guides',
          variant: 'link',
        },
      },
      {
        title: '硕士生，考虑继续读 PhD',
        description:
          '优先读：PhD 适不适合我、我的研究经历如何定位、要不要先做 Predoc 再申请。核心问题是：硕士学位帮我多少？',
        icon: 'tabler:certificate',
        callToAction: {
          text: "→ 读：Master's vs Predoc",
          href: '/guides',
          variant: 'link',
        },
      },
      {
        title: 'RA / Predoc，准备申请 PhD',
        description:
          '优先读：我的 Predoc 经历够吗、推荐信质量怎么判断、选校策略怎么定。核心问题是：现在是不是最好的申请时机？',
        icon: 'tabler:microscope',
        callToAction: {
          text: '→ 读：Recommendation Letters & School Lists',
          href: '/guides',
          variant: 'link',
        },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- How to use this site *********** -->

  <Steps
    title="如何使用这个网站"
    subtitle="Best Studio 是一个知识库，不是一个课程。你不需要按顺序读完所有内容——找到你当前面对的决策节点，直接读那篇。"
    items={[
      {
        title: '<span class="font-medium">从 Career Decisions 开始</span>',
        description:
          '如果你还不确定该走哪条路——PhD 还是 Predoc，美国还是英国——从 Career Decisions 开始。这是最上游的判断，会影响后面所有决策。',
        icon: 'tabler:git-fork',
      },
      {
        title: '<span class="font-medium">Research Experience 是核心竞争力来源</span>',
        description:
          '申请学术职位，研究经历的质量几乎决定一切。不是所有 RA 经历都等价——这里帮你判断你的经历含金量，以及如何最大化它的价值。',
        icon: 'tabler:microscope',
      },
      {
        title: '<span class="font-medium">Applications 是最后一步</span>',
        description:
          '简历、文书、推荐信——只有在前两步想清楚之后，这些材料才有方向。如果你已经确定申请方向，直接跳到 Applications。',
        icon: 'tabler:file-description',
      },
      {
        title: '<span class="font-medium">Regions 是落地场景</span>',
        description:
          '美国、英国、欧洲、香港的申请体系不同，但面对的核心问题高度一致。如果你已经锁定地区，到 Regions 查对应体系的具体情况。',
        icon: 'tabler:world',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1481627834876-b7833e8f5570?ixlib=rb-4.0.3&auto=format&fit=crop&w=1528&q=80',
      alt: 'Library books',
    }}
  />

  <!-- Common First Questions ********* -->

  <FAQs
    title="最常见的第一个问题"
    subtitle="这些是新用户最常问的问题。如果你刚接触这个网站，可以从这里入手。"
    tagline="常见问题"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Predoc 到底是什么？和 RA 有什么区别？',
        description:
          'Predoc（Pre-doctoral Fellowship）是一种正式的全职研究职位，通常时长 1-2 年，有薪水，目标是为 PhD 申请做准备。RA 泛指各种研究助理职位，可兼职可全职，含金量差异极大。Predoc 的推荐信质量通常显著高于普通 RA，因为导师有更充分的时间观察你的研究能力。',
      },
      {
        title: '我的 GPA 不够高，还有机会吗？',
        description:
          'GPA 的重要性被大多数学生高估了。对于 PhD 申请，招生委员会更关注的是：你有没有做过真正的研究？你能拿到强推吗？你的 SOP 是否清楚地说明了你的研究兴趣和能力？GPA 只是一个门槛，过了门槛之后，推荐信和研究经历才是核心。',
      },
      {
        title: '我应该套磁吗？套磁有用吗？',
        description:
          '这取决于地区和项目。美国顶级经济学 PhD 项目通常是 committee 制，套磁对录取影响有限，甚至可能起反效果。英国和欧洲更常见 PI 制，套磁对录取影响更大。香港院校差异较大。在套磁之前，先弄清楚目标项目的录取机制。',
      },
      {
        title: '我要不要先读硕士再申请 PhD？',
        description:
          '这个问题没有统一答案，取决于你的背景和目标。如果你本科研究经历很强、有好的推荐信，可以直接申 PhD。如果研究经历不足，先做 Predoc 通常比读硕士更有效——因为 Predoc 直接补的是 PhD 申请最缺的那块：研究能力的证明和高质量推荐信。',
      },
      {
        title: '我不是经济学背景，可以申请经济学 PhD 吗？',
        description:
          '可以，但要注意：顶级经济学 PhD 对数学要求极高（实分析、线代、概率论）。如果你是数学、统计、物理等定量背景，转型经济学 PhD 是可行的。如果你是社科背景，通常需要先补充定量训练，再通过 Predoc 建立经济学研究经历。',
      },
      {
        title: '一对一辅导和看指南有什么区别？',
        description:
          '指南回答的是通用问题——适用于多数人的规律和框架。一对一辅导回答的是情境化问题——你的具体背景、你的推荐信质量、你现在的处境下该怎么做。两者不是替代关系：先读指南建立基础认知，再通过一对一辅导做情境化判断。',
      },
    ]}
  />

  <!-- CTA **************************** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '浏览所有指南',
        href: '/guides',
        icon: 'tabler:book',
      },
      {
        text: '申请一对一辅导',
        href: '/mentoring',
      },
    ]}
  >
    <Fragment slot="title">
      找到你的下一步
    </Fragment>

    <Fragment slot="subtitle">
      指南帮你建立框架，一对一辅导帮你做情境化判断。<br class="hidden md:inline" />
      从你现在面对的那个最重要的决策开始。
    </Fragment>
  </CallToAction>
</Layout>
