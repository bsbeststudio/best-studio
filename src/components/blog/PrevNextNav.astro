---
import { getPermalink } from '~/utils/permalinks';
import type { Post } from '~/types';

export interface Props {
  prev: Post | null;
  next: Post | null;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="mx-auto max-w-3xl px-4 sm:px-6 mt-12 mb-4 border-t dark:border-slate-700 pt-8" aria-label="上下篇文章">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {prev ? (
        <a
          href={getPermalink(prev.permalink, 'post')}
          class="group flex flex-col gap-1 border border-gray-200 dark:border-slate-700 p-4 hover:border-primary transition-colors"
        >
          <span class="text-xs font-semibold uppercase tracking-wide text-muted">← 上一篇</span>
          <span class="mt-1 text-sm font-semibold group-hover:text-primary transition-colors line-clamp-2">
            {prev.title}
          </span>
          {prev.category && (
            <span class="text-xs text-muted">{prev.category.title}</span>
          )}
        </a>
      ) : (
        <div />
      )}

      {next ? (
        <a
          href={getPermalink(next.permalink, 'post')}
          class="group flex flex-col gap-1 border border-gray-200 dark:border-slate-700 p-4 hover:border-primary transition-colors sm:text-right"
        >
          <span class="text-xs font-semibold uppercase tracking-wide text-muted">下一篇 →</span>
          <span class="mt-1 text-sm font-semibold group-hover:text-primary transition-colors line-clamp-2">
            {next.title}
          </span>
          {next.category && (
            <span class="text-xs text-muted">{next.category.title}</span>
          )}
        </a>
      ) : (
        <div />
      )}
    </div>
  </nav>
)}
