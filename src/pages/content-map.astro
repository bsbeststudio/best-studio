---
import Layout from '~/layouts/PageLayout.astro';
import { getClusterItems, statusLabels, topicClusters, typeLabels } from '~/data/topicClusters';

// 为每个 cluster 预取合并后的条目（已发布 + 规划中）
const clusterItems = Object.fromEntries(
  await Promise.all(topicClusters.map(async (c) => [c.slug, await getClusterItems(c.slug)]))
);

const metadata = {
  title: '内容地图',
  description: 'Best Studio 中文主题集群和未来文章规划地图。',
  canonical: '/content-map',
  openGraph: { type: 'website', url: '/content-map' },
};

const statusClass = {
  Published: 'text-green-700 dark:text-green-300',
  Draft: 'text-blue-700 dark:text-blue-300',
  Planned: 'text-muted',
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">首页</a><span class="mx-2">/</span><span>内容地图</span>
    </nav>
  </section>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">Content Map</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      Hub + Topic Cluster 路线图。
    </h1>
    <p class="mt-5 max-w-3xl text-xl text-muted">
      这个页面展示 Best Studio 的内容结构：四个主题 Hub、已发布和规划中的指南，以及每篇文章的类型和状态。
    </p>
  </section>
  <section class="px-4 md:px-6 py-8 mx-auto max-w-6xl">
    <div class="grid gap-6 lg:grid-cols-2">
      {
        topicClusters.map((cluster) => (
          <article class="border border-gray-200 dark:border-slate-700 p-6">
            <>
              <p class="text-sm font-semibold text-primary">{cluster.kicker}</p>
              <h2 class="mt-2 text-2xl font-bold">{cluster.title}</h2>
              <p class="mt-2 text-sm text-muted">{cluster.primaryQuestion}</p>
              <ul class="mt-5 space-y-3">
                {clusterItems[cluster.slug].map((item) => (
                  <li class="flex gap-3 text-sm">
                    <span class="w-20 shrink-0 font-semibold">{typeLabels[item.type]}</span>
                    <a class="grow hover:underline" href={item.href}>
                      {item.title}
                    </a>
                    <span class={`shrink-0 ${statusClass[item.status]}`}>{statusLabels[item.status]}</span>
                  </li>
                ))}
              </ul>
            </>
          </article>
        ))
      }
    </div>
  </section>
  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="border border-gray-200 dark:border-slate-700 p-6 md:p-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">编辑说明</p>
      <h2 class="mt-2 text-2xl font-bold tracking-tight">内容优先级与扩展方向</h2>
      <p class="mt-3 text-muted max-w-3xl">
        Best Studio 的扩展策略是：先深化已有 Hub 的覆盖密度，再开拓新主题。每篇指南至少覆盖 3000 字，包含真实的案例逻辑和内部链接，再考虑添加新文章。
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-3 text-sm">
        <div>
          <p class="font-bold">已完成（Published）</p>
          <p class="mt-1 text-muted">已经发布、可以被 Google 索引的完整指南，覆盖核心申请路径的主要决策点。</p>
        </div>
        <div>
          <p class="font-bold">草稿（Draft）</p>
          <p class="mt-1 text-muted">已经开始写但尚未完成的内容，预计在本季度内完成并发布。</p>
        </div>
        <div>
          <p class="font-bold">规划中（Planned）</p>
          <p class="mt-1 text-muted">已经识别为有读者需求的选题，但尚未开始撰写。有想读的选题，欢迎通过辅导页面告知。</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
