---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import { getTopicPages, getClusterItems, typeLabels } from '~/data/topicClusters';
import { fetchPosts } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async () => {
  const allPosts = await fetchPosts();
  const postSlugs = new Set(allPosts.map((p) => p.slug));

  return (await getTopicPages()).map((topic) => ({
    params: { slug: topic.slug },
    props: { topic, hasPost: postSlugs.has(topic.slug) },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { topic, hasPost } = Astro.props as Props;

// If a real guide post exists, redirect there (301)
if (hasPost) {
  return Astro.redirect(`/guides/${topic.slug}`, 301);
}

// Get related published content from the same cluster
const clusterItems = await getClusterItems(topic.cluster.slug);
const relatedPublished = clusterItems.filter((item) => item.status === 'Published').slice(0, 4);

const isPublished = topic.status === 'Published';
const metadata = {
  title: `${topic.title} | Best Studio`,
  ignoreTitleTemplate: true,
  description: topic.description,
  canonical: topic.canonical,
  robots: { index: isPublished, follow: true },
  openGraph: { type: 'article', url: topic.canonical },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-4xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      {
        topic.breadcrumbs.map((item, index) => (
          <>
            {index > 0 && <span class="mx-2">/</span>}
            {index < topic.breadcrumbs.length - 1 ? (
              <a class="hover:underline" href={item.href}>
                {item.text}
              </a>
            ) : (
              <span>{item.text}</span>
            )}
          </>
        ))
      }
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">{typeLabels[topic.type]} · {topic.cluster.title}</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">{topic.title}</h1>
    <p class="mt-5 text-xl text-muted">{topic.description}</p>
    <div class="mt-8 inline-flex items-center gap-2 rounded-full bg-amber-50 px-4 py-2 text-sm text-amber-800 dark:bg-amber-900/20 dark:text-amber-200">
      <span>⏳</span>
      <span>这篇文章正在撰写中。可以先阅读下方「{topic.cluster.title}」主题下已发布的相关内容。</span>
    </div>
  </section>

  {relatedPublished.length > 0 && (
    <section class="px-4 md:px-6 pb-12 mx-auto max-w-4xl">
      <h2 class="text-2xl font-bold tracking-tight">「{topic.cluster.title}」相关阅读</h2>
      <p class="mt-2 text-muted">以下文章已发布，与本主题高度相关：</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          relatedPublished.map((item) => (
            <a
              class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary transition-colors"
              href={item.href}
            >
              <span class="text-xs font-semibold uppercase tracking-wide text-primary">{typeLabels[item.type]}</span>
              <p class="mt-2 font-semibold leading-snug">{item.title}</p>
            </a>
          ))
        }
      </div>
      <div class="mt-6">
        <a class="text-sm font-semibold text-primary hover:underline" href={`/${topic.cluster.slug}`}>
          查看「{topic.cluster.title}」全部内容 →
        </a>
      </div>
    </section>
  )}

  <section class="px-4 md:px-6 py-10 mx-auto max-w-4xl">
    <div class="border border-primary/40 bg-gray-50 dark:bg-slate-900 p-6 md:p-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">需要现在就解答这个问题？</p>
      <h2 class="mt-2 text-2xl font-bold tracking-tight">这篇文章还没写完，但这个问题可以在辅导里直接讨论。</h2>
      <p class="mt-3 text-muted">
        如果这个话题对你的申请决策很紧迫，预约 1 对 1 辅导可以针对你的具体情况做深入分析，而不是等一篇通用文章。
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/mentoring">了解辅导服务</a>
        <a class="btn" href={`/${topic.cluster.slug}`}>回到「{topic.cluster.title}」</a>
      </div>
    </div>
  </section>
</Layout>
