---
import Layout from '~/layouts/PageLayout.astro';
import { topicClusters } from '~/data/topicClusters';

const metadata = {
  title: 'Start Here',
  description: 'Find the right Best Studio topic cluster for your current stage in academic career planning.',
  canonical: '/start-here',
  openGraph: {
    type: 'website',
    url: '/start-here',
  },
};

const stages = [
  {
    title: 'I am exploring whether research is for me',
    description: 'Start with research careers before optimizing for applications.',
    href: '/research-careers',
  },
  {
    title: 'I need stronger research experience',
    description: 'Focus on RA roles, independent work, and evidence of research potential.',
    href: '/research-experience',
  },
  {
    title: 'I am considering RA or predoc roles',
    description: 'Compare the value of full-time research roles, timelines, and opportunity costs.',
    href: '/ra-predoc',
  },
  {
    title: 'I am preparing PhD applications',
    description: 'Move into school lists, CV, SOP, recommendations, interviews, and timing.',
    href: '/phd-applications',
  },
];
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">Home</a>
      <span class="mx-2">/</span>
      <span>Start Here</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">Start Here</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      Find your current decision point.
    </h1>
    <p class="mt-5 max-w-3xl text-xl text-muted">
      Best Studio is organized as a hub and topic cluster knowledge site. You do not need to read everything in order;
      start with the decision that matches your stage.
    </p>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-6xl">
    <div class="grid gap-5 md:grid-cols-2">
      {
        stages.map((stage) => (
          <a class="block border border-gray-200 dark:border-slate-700 p-6 hover:border-primary" href={stage.href}>
            <h2 class="text-xl font-bold">{stage.title}</h2>
            <p class="mt-3 text-muted">{stage.description}</p>
            <p class="mt-5 text-sm font-semibold text-primary">Go to this hub</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="px-4 md:px-6 py-12 mx-auto max-w-6xl">
    <div class="mb-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">Full Map</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight">All current topic clusters</h2>
    </div>
    <div class="grid gap-4">
      {
        topicClusters.map((cluster) => (
          <div class="border border-gray-200 dark:border-slate-700 p-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h3 class="text-lg font-bold">{cluster.title}</h3>
                <p class="mt-1 text-sm text-muted">{cluster.primaryQuestion}</p>
              </div>
              <a class="text-sm font-semibold text-primary hover:underline" href={`/${cluster.slug}`}>
                Open hub
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Table of Contents Placeholder</h2>
        <p class="mt-3 text-sm text-muted">Stage selector, full map, related guides, and future FAQ.</p>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Related Articles Placeholder</h2>
        <p class="mt-3 text-sm text-muted">Future beginner reading paths will appear here.</p>
      </div>
    </div>
  </section>
</Layout>
