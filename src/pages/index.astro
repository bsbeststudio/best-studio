---
import Layout from '~/layouts/PageLayout.astro';
import { topicClusters } from '~/data/topicClusters';

const metadata = {
  title: 'Best Studio | Academic Career Planning',
  ignoreTitleTemplate: true,
  description:
    'A hub and topic cluster knowledge site for research-oriented students planning research careers, RA and predoc paths, and PhD applications.',
  canonical: '/',
  openGraph: {
    type: 'website',
    url: '/',
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <span>Home</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary">Academic Career Planning</p>
        <h1 class="mt-4 font-bold font-heading text-4xl md:text-6xl leading-tighter tracking-tighter">
          A knowledge hub for early research careers.
        </h1>
        <p class="mt-6 text-xl text-muted">
          Best Studio organizes academic career planning around the decisions students actually face: whether to pursue
          research, how to build research experience, when RA or predoc roles help, and how PhD applications are
          evaluated.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary" href="/start-here">Start Here</a>
          <a class="btn" href="/content-map">View Content Map</a>
        </div>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-6">
        <p class="text-sm font-semibold text-muted">Built for scale</p>
        <dl class="mt-6 grid grid-cols-2 gap-6">
          <div>
            <dt class="text-3xl font-bold">4</dt>
            <dd class="text-sm text-muted">Core topic hubs now</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold">26+</dt>
            <dd class="text-sm text-muted">Reserved article slots</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold">5</dt>
            <dd class="text-sm text-muted">Content types</dd>
          </div>
          <div>
            <dt class="text-3xl font-bold">100s</dt>
            <dd class="text-sm text-muted">Future guides supported</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-6 py-12 mx-auto max-w-6xl">
    <div class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">Topic Clusters</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight">Choose the decision you are facing</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {
        topicClusters.map((cluster) => (
          <a
            class="block border border-gray-200 dark:border-slate-700 p-6 hover:border-primary"
            href={`/${cluster.slug}`}
          >
            <p class="text-sm font-semibold text-primary">{cluster.kicker}</p>
            <h3 class="mt-2 text-2xl font-bold">{cluster.title}</h3>
            <p class="mt-3 text-muted">{cluster.description}</p>
            <p class="mt-5 text-sm font-semibold">Open hub</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Table of Contents Placeholder</h2>
        <p class="mt-3 text-sm text-muted">Hero, topic clusters, related articles, and future homepage FAQ.</p>
      </div>
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">Related Articles Placeholder</h2>
        <p class="mt-3 text-sm text-muted">Future featured guides and decision pages will appear here.</p>
      </div>
    </div>
  </section>
</Layout>
