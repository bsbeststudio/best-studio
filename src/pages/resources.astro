---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '资源',
  description: '面向中国学生的学术申请资源库：模板、清单、数据和决策工具。',
  canonical: '/resources',
  openGraph: { type: 'website', url: '/resources' },
};

const resourceGroups = [
  { title: '模板', items: ['RA / Predoc 套磁邮件模板', '推荐信请求邮件', 'Academic CV 结构', '选校分析表'] },
  { title: '清单', items: ['科研经历自查', 'Predoc Offer 评估', 'PhD 申请准备度', 'SOP 检查清单'] },
  { title: '数据', items: ['Predoc 项目数据库', '申请时间线追踪表', 'Placement 去向记录', '地区申请体系对比'] },
];
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">首页</a><span class="mx-2">/</span><span>资源</span>
    </nav>
  </section>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">Resources</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      可复用的工具会放在这里。
    </h1>
    <p class="mt-5 max-w-3xl text-xl text-muted">这个页面预留给支持主题 Hub 的实用资源：模板、清单、数据和决策表格。</p>
  </section>
  <section class="px-4 md:px-6 py-8 mx-auto max-w-6xl">
    <div class="grid gap-5 md:grid-cols-3">
      {
        resourceGroups.map((group) => (
          <div class="border border-gray-200 dark:border-slate-700 p-6">
            <>
              <h2 class="text-xl font-bold">{group.title}</h2>
              <ul class="mt-4 space-y-3 text-sm text-muted">
                {group.items.map((item) => (
                  <li class="border-l border-gray-200 pl-3 dark:border-slate-700">{item}</li>
                ))}
              </ul>
              <p class="mt-5 text-sm font-semibold text-primary">未来内容占位</p>
            </>
          </div>
        ))
      }
    </div>
  </section>
  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">目录占位</h2><p class="mt-3 text-sm text-muted">
          模板、清单、数据、相关文章和未来 FAQ。
        </p>
      </div><div class="border border-gray-200 dark:border-slate-700 p-5">
        <h2 class="text-lg font-bold">相关文章占位</h2><p class="mt-3 text-sm text-muted">
          未来和资源相关的指南会放在这里。
        </p>
      </div>
    </div>
  </section>
</Layout>
