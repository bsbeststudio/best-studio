---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '申请资源库 | Best Studio',
  description: '面向中国学生的学术申请资源库：Cover Letter 模板、推荐信请求邮件、Predoc Offer 评估清单、申请时间线追踪表。',
  canonical: '/resources',
  openGraph: { type: 'website', url: '/resources' },
};

const resourceGroups = [
  {
    title: '模板',
    description: '可直接使用的邮件和文档结构，根据自己的情况调整内容。',
    items: [
      { name: 'RA / Predoc 套磁邮件模板', note: '基于"以 PI 为中心"原则的四段结构', link: '/guides/cold-email-guide' },
      { name: 'Cover Letter 四段结构', note: 'Predoc 求职信的完整写作框架', link: '/guides/cover-letter-guide' },
      { name: '推荐信请求邮件', note: '给推荐人的工作摘要模板', link: '/guides/recommendation-letters' },
      { name: 'Academic CV 结构', note: '经济学 PhD 申请简历格式', link: '/guides/academic-cv-guide' },
    ],
  },
  {
    title: '清单',
    description: '申请过程中的自查工具，确认没有遗漏关键步骤。',
    items: [
      { name: '科研经历自查', note: '判断你的 RA 经历真正传递了什么信号', link: '/guides/research-experience-quality' },
      { name: 'Predoc Offer 评估', note: '接受 offer 前的三个核心维度', link: '/guides/advisor-signal-decoding' },
      { name: 'PhD 申请准备度', note: '12 个月规划倒推表', link: '/guides/phd-application-timeline' },
      { name: 'SOP 检查清单', note: '材料叙事一致性验证', link: '/guides/narrative-fragmentation' },
    ],
  },
  {
    title: '决策工具',
    description: '帮你在关键节点做出有依据的判断，而不是凭感觉。',
    items: [
      { name: 'RA vs Predoc 决策框架', note: '根据你的具体情况判断哪条路更优', link: '/guides/ra-vs-predoc' },
      { name: '谁不应该做 Predoc', note: '六种可能不适合 Predoc 的情况', link: '/guides/who-should-not-do-predoc' },
      { name: '学术 vs 工业路径', note: '结构性差异对比', link: '/guides/should-you-do-phd' },
      { name: '选校策略', note: '冲刺 / 匹配 / 保底如何分配', link: '/guides/school-list-strategy' },
    ],
  },
];

const relatedArticles = [
  { title: '套磁邮件怎么写？', href: '/guides/cold-email-guide', category: 'RA & Predoc' },
  { title: 'Predoc Cover Letter 怎么写？', href: '/guides/cover-letter-guide', category: 'RA & Predoc' },
  { title: 'Academic CV 怎么写？', href: '/guides/academic-cv-guide', category: 'PhD 申请' },
  { title: 'PhD 申请时间线：12 个月规划', href: '/guides/phd-application-timeline', category: 'PhD 申请' },
];
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 pt-8 mx-auto max-w-6xl">
    <nav class="text-sm text-muted" aria-label="Breadcrumb">
      <a class="hover:underline" href="/">首页</a><span class="mx-2">/</span><span>资源</span>
    </nav>
  </section>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">Resources</p>
    <h1 class="mt-4 font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      申请资源库
    </h1>
    <p class="mt-5 max-w-3xl text-xl text-muted">
      汇总申请过程中最常用的模板、清单和决策工具。每个资源都链接到对应的完整指南，方便查阅背后的逻辑。
    </p>
  </section>

  <section class="px-4 md:px-6 py-8 mx-auto max-w-6xl">
    <div class="grid gap-8 md:grid-cols-3">
      {
        resourceGroups.map((group) => (
          <div class="border border-gray-200 dark:border-slate-700 p-6">
            <h2 class="text-xl font-bold">{group.title}</h2>
            <p class="mt-2 text-sm text-muted">{group.description}</p>
            <ul class="mt-5 space-y-4">
              {group.items.map((item) => (
                <li>
                  <a class="font-medium hover:text-primary hover:underline" href={item.link}>
                    {item.name}
                  </a>
                  <p class="mt-0.5 text-xs text-muted">{item.note}</p>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-4 md:px-6 py-10 mx-auto max-w-6xl">
    <h2 class="text-2xl font-bold tracking-tight">相关指南</h2>
    <p class="mt-2 text-muted">资源背后的完整分析和上下文。</p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        relatedArticles.map((article) => (
          <a
            class="block border border-gray-200 dark:border-slate-700 p-5 hover:border-primary transition-colors"
            href={article.href}
          >
            <span class="text-xs font-semibold uppercase tracking-wide text-primary">{article.category}</span>
            <p class="mt-2 font-semibold leading-snug">{article.title}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="px-4 md:px-6 py-12 mx-auto max-w-6xl">
    <div class="border border-primary/40 bg-gray-50 dark:bg-slate-900 p-6 md:p-8">
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">需要针对你的情况分析？</p>
      <h2 class="mt-2 text-2xl font-bold tracking-tight">通用资源解决通用问题。你的情况是独特的。</h2>
      <p class="mt-3 text-muted">如果你的背景、时间线或目标需要具体分析，1 对 1 辅导能针对你的真实情况给出判断——而不是套用模板。</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/mentoring">了解辅导服务</a>
        <a class="btn" href="/start-here">从这里开始阅读</a>
      </div>
    </div>
  </section>
</Layout>
