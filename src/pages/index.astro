---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Best Studio</h1>

				<h2>学术早期职业规划</h2>

				<p>
				帮助研究导向学生做更好的学术职业决策。
				</p>

				<p>
				我们专注于 Economics、Finance、Marketing、Business、Public Policy
				等研究导向学科，覆盖美国、英国、欧洲及香港的
				RA、Predoc 与 PhD 申请规划。
				</p>
			</section>

			<section>
				<h2>从这里开始</h2>

				<ul>
				<li><a href="/blog">阅读全部文章</a></li>
				<li><a href="/blog/start-here">什么是学术规划？</a></li>
				<li><a href="/blog/predoc-guide">Predoc 指南（Coming Soon）</a></li>
				<li><a href="/blog/phd-application">PhD 申请指南（Coming Soon）</a></li>
				</ul>
			</section>

			<section>
				<h2>我们的理念</h2>

				<p>
				我们相信，成功来自更好的判断，而不是更多的信息。
				</p>

				<p>
				我们不提供流水线申请服务，而是帮助你理解自己的处境、
				学术体系的规则，以及下一步最值得投入的方向。
				</p>
			</section>
			</main>
		<Footer />
	</body>
</html>
